        <Palette id="4" src="Burnt.png"/>
        <Palette id="5" src="Mushroom.png"/>
        <Palette id="6" src="Toadstool.png"/>
    </PaletteList>
    <RasterList>
        <Raster id="0" palette="0" src="Step1.png"/>
        <Raster id="1" palette="0" src="Step2.png"/>
        <Raster id="2" palette="0" src="Step3.png"/>
        <Raster id="3" palette="0" src="Hurt1.png"/>
        <Raster id="4" palette="0" src="Hurt2.png"/>
