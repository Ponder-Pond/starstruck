                <Wait duration="8"/>
                <SetRaster index="B"/>
                <Wait duration="8"/>
                <SetRaster index="C"/>
                <Wait duration="8"/>
                <Goto dest="Start"/>
            </Component>
        </Animation>
        <Animation name="Sleep">
            <Component name="Body" xyz="0,0,0">
                <Label name="Start"/>
                <SetRaster index="8"/>
                <Wait duration="2"/>
                <Goto dest="Start"/>
            </Component>
        </Animation>
        <Animation name="BurnHurt">
            <Component name="Body" xyz="0,0,0">
                <Label name="Start"/>
                <SetRaster index="D"/>
                <Wait duration="8"/>
                <SetRaster index="E"/>
                <Wait duration="8"/>
