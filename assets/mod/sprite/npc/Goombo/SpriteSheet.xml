        </Animation>
        <Animation name="Tense">
            <Component name="Body" xyz="0,-20,0">
                <Label name="Start"/>
                <SetPos flag="1" xyz="0,8,0"/>
                <SetRaster index="10"/>
                <Wait duration="2"/>
                <Goto dest="Start"/>
            </Component>
        </Animation>
        <Animation name="FakeToadstool">
            <Component name="Toadstool" xyz="1,0,0">
                <Label name="Start"/>
                <SetRaster index="11"/>
                <Wait duration="2"/>
                <Goto dest="Start"/>
            </Component>
        </Animation>
        <Animation name="FakeMushroom">
            <Component name="Mushroom" xyz="1,0,0">
                <Label name="Start"/>
                <SetRaster index="12"/>
                <Wait duration="2"/>
                <Goto dest="Start"/>
            </Component>
        </Animation>
        <Animation name="Electrocute">
            <Component name="Body" xyz="0,0,0">
