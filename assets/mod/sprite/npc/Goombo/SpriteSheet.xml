                <SetRaster index="0"/>
                <Wait duration="2"/>
                <SetRaster index="2"/>
                <Wait duration="4"/>
                <Goto dest="Start"/>
            </Component>
        </Animation>
        <Animation name="Midair">
            <Component name="Body" xyz="0,-20,0">
                <Label name="Start"/>
                <SetRaster index="5"/>
                <Wait duration="2"/>
                <Goto dest="Start"/>
            </Component>
        </Animation>
        <Animation name="Hurt">
            <Component name="Body" xyz="0,0,0">
                <Label name="Start"/>
                <SetRaster index="3"/>
                <Wait duration="4"/>
                <SetRaster index="4"/>
                <Wait duration="4"/>
                <Goto dest="Start"/>
            </Component>
        </Animation>
        <Animation name="Dead">
            <Component name="Body" xyz="0,0,0">
