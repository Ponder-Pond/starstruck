        <Raster id="12" palette="2" src="Mushroom.png"/>
        <Raster id="13" palette="1" src="XRay.png"/>
    </RasterList>
    <AnimationList>
        <Animation name="Still">
            <Component name="Body" xyz="0,0,0">
                <Label name="Start"/>
                <SetRaster index="0"/>
                <Wait duration="2"/>
                <Goto dest="Start"/>
            </Component>
        </Animation>
        <Animation name="Idle">
            <Component name="Body" xyz="0,0,0">
                <Label name="Start"/>
                <SetRaster index="0"/>
                <Wait duration="8"/>
                <SetRaster index="6"/>
                <Wait duration="8"/>
                <SetRaster index="0"/>
                <Wait duration="8"/>
                <SetRaster index="6"/>
                <Wait duration="8"/>
                <SetRaster index="0"/>
                <Wait duration="8"/>
                <SetRaster index="6"/>
                <Wait duration="8"/>
                <SetRaster index="0"/>
                <Wait duration="8"/>
                <SetRaster index="6"/>
                <Wait duration="8"/>
                <SetRaster index="7"/>
                <Wait duration="20"/>
                <SetRaster index="6"/>
                <Wait duration="8"/>
                <Goto dest="Start"/>
            </Component>
        </Animation>
        <Animation name="Walk">
            <Component name="Body" xyz="0,0,0">
                <Label name="Start"/>
                <SetRaster index="0"/>
                <Wait duration="8"/>
                <SetRaster index="1"/>
